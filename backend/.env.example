# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Groq AI
GROQ_API_KEY=your-groq-api-key

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-pem
VAPID_CONTACT=mailto:admin@campusai.app

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Backend public URL (used to build CAS redirect callback URLs)
# Set to your Render URL in production, e.g. https://campusai-backend.onrender.com
BACKEND_URL=http://localhost:8000
